# Server
PORT=5000
BASE_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_image_db

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# AI provider: pollinations (free, no key) | stability | huggingface
IMAGE_PROVIDER=pollinations
STABILITY_API_KEY=
HF_API_KEY=
HF_MODEL=stabilityai/stable-diffusion-xl-base-1.0
